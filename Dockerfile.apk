# Force x86-64: Android build tools (AAPT2) ship as x86-64 Linux binaries only
FROM --platform=linux/amd64 eclipse-temurin:17-jdk-jammy

ENV ANDROID_HOME=/opt/android-sdk
ENV GRADLE_VERSION=8.7
ENV PATH=$PATH:$ANDROID_HOME/cmdline-tools/latest/bin:$ANDROID_HOME/platform-tools:$ANDROID_HOME/build-tools/34.0.0:/opt/gradle/bin

RUN apt-get update && apt-get install -y wget unzip python3 python3-pip webp && \
    pip3 install Pillow && \
    rm -rf /var/lib/apt/lists/*

# Gradle
RUN wget -q https://services.gradle.org/distributions/gradle-${GRADLE_VERSION}-bin.zip -O /tmp/gradle.zip && \
    unzip -q /tmp/gradle.zip -d /opt && \
    mv /opt/gradle-${GRADLE_VERSION} /opt/gradle && \
    rm /tmp/gradle.zip

# Android SDK command-line tools
RUN wget -q https://dl.google.com/android/repository/commandlinetools-linux-11076708_latest.zip -O /tmp/tools.zip && \
    mkdir -p $ANDROID_HOME/cmdline-tools && \
    unzip -q /tmp/tools.zip -d $ANDROID_HOME/cmdline-tools && \
    mv $ANDROID_HOME/cmdline-tools/cmdline-tools $ANDROID_HOME/cmdline-tools/latest && \
    rm /tmp/tools.zip

RUN yes | sdkmanager --licenses > /dev/null 2>&1 && \
    sdkmanager "platforms;android-34" "build-tools;34.0.0"

WORKDIR /build
COPY android-app/ ./android-app/
COPY build_apk.py .

# Pre-warm Gradle cache (speeds up subsequent builds)
RUN echo "sdk.dir=$ANDROID_HOME" > android-app/local.properties && \
    gradle -p android-app assembleDebug --no-daemon -q 2>/dev/null || true

ENTRYPOINT ["python3", "build_apk.py"]
